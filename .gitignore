# Logs & output
*-log.txt
scripts/*-log.txt
output/*
!output/.gitkeep
cookies/*
!cookies/.gitkeep
migration/**/*
!migration/**/.gitkeep

# Local data (keep examples)
.env
profiles.csv
proxies.txt
keywords.txt
live_comments.txt
mentions.txt

# Private dev tooling (local only — never publish)
AUTO-COMMIT.bat
PUBLISH.bat
LOGIN-GITHUB.bat
SET-GITHUB-SEO.bat
scripts/auto-commit.ps1
scripts/publish.ps1
scripts/login-github.ps1
scripts/set-github-topics.ps1
scripts/legacy/
scripts/*-log.txt

# Python
__pycache__/
*.py[cod]
.venv
venv/
*.egg-info/
dist/
build/

# IDE
.vscode/
.DS_Store

# Screenshots (except README assets)
*.png
!README*.png
